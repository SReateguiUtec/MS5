# MS5 — Analítica de Mercado (AWS Athena)
# Copia este archivo como .env y rellena los valores reales.
# Si AWS_ACCESS_KEY_ID o AWS_SECRET_ACCESS_KEY están vacíos,
# el servicio arranca en MOCK MODE y devuelve datos de ejemplo.

# Credenciales AWS
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# Athena
ATHENA_DATABASE=findtrend
ATHENA_OUTPUT_BUCKET=s3://findtrend-athena-results
